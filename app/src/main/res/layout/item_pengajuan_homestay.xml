<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon Container -->
        <FrameLayout
            android:id="@+id/iconContainer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_badge_capsule"
            android:backgroundTint="@color/softRed">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🏡"
                android:textSize="20sp" />
        </FrameLayout>

        <!-- Delete Button -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Hapus Pengajuan"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/primaryRed" />

        <!-- Info Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/iconContainer"
            android:layout_toStartOf="@id/btnDelete"
            android:layout_marginHorizontal="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaHomestay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/textDark"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Homestay Melati" />

            <TextView
                android:id="@+id/tvAlamat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/textGray"
                android:textSize="12sp"
                tools:text="Lokasi: RT 02 / RW 05, Desa Wisata Merah" />

            <TextView
                android:id="@+id/tvHarga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/primaryRed"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="Harga: Rp 250.000 / malam" />

            <TextView
                android:id="@+id/tvPendaftar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/textGray"
                android:textSize="11sp"
                tools:text="Oleh: Budi (Pemilik)" />

            <!-- Date Pill -->
            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_badge_capsule"
                android:backgroundTint="#F0F0F0"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:textColor="@color/textGray"
                android:textSize="10sp"
                android:textStyle="bold"
                tools:text="10 Jun 2026" />

        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="30dp"
    android:background="#FFF5F5">

    <!-- Logo -->
    <ImageView
        android:id="@+id/imageView6"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="20dp"
        app:srcCompat="@drawable/chatgpt_image_apr_22__2026__08_29_16_pm"/>

    <!-- Judul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bina Desa Pariwisata"
        android:textColor="#B71C1C"
        android:textStyle="bold"
        android:textSize="28sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistem Informasi Homestay"
        android:textColor="#D32F2F"
        android:textSize="18sp"
        android:layout_marginBottom="30dp"/>

    <!-- Username -->
    <EditText
        android:id="@+id/edtUsername"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Masukkan Username"
        android:padding="15dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="15dp"/>

    <!-- Password -->
    <EditText
        android:id="@+id/edtPassword"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Masukkan Password"
        android:padding="15dp"
        android:inputType="textPassword"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="25dp"/>

    <!-- Tombol Login -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Masuk Website"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:backgroundTint="#C62828"/>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kelola Pariwisata dan Homestay Desa"
        android:textColor="#8D6E63"
        android:textSize="13sp"
        android:layout_marginTop="24dp"/>

</LinearLayout>
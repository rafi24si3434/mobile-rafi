<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#1E293B"
        app:title="Pertemuan 7"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Tombol Fragment -->

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Halaman Pertemuan 7"
        android:textColor="#111827"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <Button
        android:id="@+id/btnfragment1"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:text="Fragment 1"
        app:layout_constraintEnd_toStartOf="@id/btnfragment2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <Button
        android:id="@+id/btnfragment2"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:text="Fragment 2"
        app:layout_constraintBottom_toBottomOf="@id/btnfragment1"
        app:layout_constraintEnd_toStartOf="@id/btnfragment3"
        app:layout_constraintStart_toEndOf="@id/btnfragment1"
        app:layout_constraintTop_toTopOf="@id/btnfragment1"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/btnfragment3"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="Fragment 3"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/btnfragment1"
        app:layout_constraintBottom_toBottomOf="@id/btnfragment1"
        app:layout_constraintStart_toEndOf="@id/btnfragment2"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Container Fragment -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="388dp"
        android:layout_height="554dp"
        android:layout_margin="16dp"
        android:background="#E5E7EB"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnfragment1"
        app:layout_constraintVertical_bias="1.0" />

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- News Image Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="86dp"
            android:layout_height="86dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/softBackground">

            <ImageView
                android:id="@+id/ivNewsThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="News Image" />
        </androidx.cardview.widget.CardView>

        <!-- News Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <!-- Source & Date -->
            <TextView
                android:id="@+id/tvNewsSourceDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BBC News • Baru saja"
                android:textColor="@color/primaryRed"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- News Title -->
            <TextView
                android:id="@+id/tvNewsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Judul Berita Terbaru"
                android:textColor="@color/textDark"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.1" />

            <!-- News Description -->
            <TextView
                android:id="@+id/tvNewsDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Deskripsi singkat mengenai berita yang ditarik dari API public untuk dicantumkan pada bagian dashboard."
                android:textColor="@color/textGray"
                android:textSize="11sp"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <!-- Header -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:background="#8B0000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="167dp"
        android:layout_height="169dp"
        android:layout_marginTop="38dp"
        android:scaleType="fitCenter"
        android:src="@drawable/chatgpt_image_apr_22__2026__08_29_16_pm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/mainCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bina Desa Pariwisata"
                android:textStyle="bold"
                android:textSize="26sp"
                android:textColor="#111111"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sistem Informasi Homestay"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="28dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Utama"
                android:textStyle="bold"
                android:textSize="22sp"
                android:textColor="#1F2A44"
                android:layout_marginBottom="24dp"/>

            <!-- Tombol Website -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWebsite"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Akses Website Bina Desa"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C62828"
                app:cornerRadius="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Tombol Logout -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:text="Logout Sistem"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#8B0000"
                app:cornerRadius="16dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pengelolaan Desa Wisata dan Homestay Digital"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/softBackground">

    <!-- Graphics/Illustration Area with layered premium depth -->
    <FrameLayout
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="48dp"
        android:gravity="center">

        <!-- Outer Soft Colored Halo Circle -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_white"
            android:backgroundTint="@color/softRed" />

        <!-- Inner White Card Circle with Elevation -->
        <FrameLayout
            android:layout_width="165dp"
            android:layout_height="165dp"
            android:layout_gravity="center"
            android:elevation="6dp"
            android:background="@drawable/circle_white">

            <TextView
                android:id="@+id/tvSlideGraphic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🌴"
                android:textSize="72sp" />

        </FrameLayout>

    </FrameLayout>

    <!-- Slide Title -->
    <TextView
        android:id="@+id/tvSlideTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Judul Slide"
        android:textColor="@color/textDark"
        android:textSize="24sp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="16dp" />

    <!-- Slide Description -->
    <TextView
        android:id="@+id/tvSlideDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Deskripsi detail dari slide onboarding ini yang menjelaskan fitur aplikasi secara lengkap dan menarik."
        android:textColor="@color/textGray"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:lineSpacingMultiplier="1.3" />

</LinearLayout>

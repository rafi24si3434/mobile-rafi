<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".Home.HomeFragment">

    <View
        android:id="@+id/headerView"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="#1E1B4B"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Halo, Rafi! 👨‍💻"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginStart="24dp"
        android:layout_marginTop="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSubGreeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dashboard Akademik  Modul Mobile"
        android:textColor="#A5B4FC"
        android:textSize="16sp"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="@id/tvGreeting"
        app:layout_constraintTop_toBottomOf="@id/tvGreeting"/>


    <androidx.cardview.widget.CardView
        android:id="@+id/cardTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubGreeting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:padding="20dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Pemrograman Mobile - Sistem Informasi"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#111827"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp"/>

            <LinearLayout
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Presentasi"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="95"
                        android:textColor="#10B981"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Grade"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="A"
                        android:textColor="#3B82F6"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Kehadiran"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="100%"
                        android:textColor="#F59E0B"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>


    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardTitle"
        app:layout_constraintBottom_toTopOf="@id/btnLogout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnPertemuan2"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:text="📖 Akses Pertemuan 2"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:backgroundTint="#3B82F6"/>

            <Button
                android:id="@+id/btnPertemuan3"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="16dp"
                android:text="💻 Akses Pertemuan 3"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:backgroundTint="#8B5CF6"/>

            <Button
                android:id="@+id/btnPertemuan4"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="16dp"
                android:text="🚀 Akses Pertemuan 4"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:backgroundTint="#EC4899"/>

            <Button
                android:id="@+id/btnPertemuan5"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="16dp"
                android:text="🎯 Akses Pertemuan 5"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:backgroundTint="#10B981"/>

            <Button
                android:id="@+id/btnPertemuan7"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:layout_marginTop="16dp"
                android:text="🏆 Akses Pertemuan 7"
                android:textColor="#FFF"
                android:textStyle="bold"
                android:backgroundTint="#F59E0B"/>

        </LinearLayout>

    </ScrollView>


    <Button
        android:id="@+id/btnLogout"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="🚪 Keluar Akun"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#EF4444"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>